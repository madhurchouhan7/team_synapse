# ─────────────────────────────────────────────────────────────────────────────
# Root Workspace / Documentation Env File
# This file serves as an overview of required environment variables for the monorepo.
#
# NOTE: The actual working environment variables should go strictly into:
#       --> backend/.env
#
# To quickly start: `cp example.env backend/.env` and update values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server configuration ──
PORT=5000
NODE_ENV=development

# ── Database & Caching ──
# MongoDB Atlas URI or Local MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/wattsense
# Redis instance used for queueing, rate-limiting, and caching Tuya Tokens
REDIS_URL=redis://localhost:6379

# ── Firebase Admin SDK ──
# Used for backend authentication validation and push notifications
FIREBASE_PROJECT_ID=your-wattwise-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account.json

# ── AI API Credentials ──
# Main generative model for efficiency and bill breakdown agents
GEMINI_API_KEY=AIzaSyB_Your_Gemini_Key_Here

# ── Tuya IoT Credentials (Hardware Telemetry) ──
# Acquired from https://iot.tuya.com
TUYA_CLIENT_ID=your_tuya_access_key_here
TUYA_CLIENT_SECRET=your_tuya_secret_key_here
TUYA_BASE_URL=https://openapi.tuyaeu.com 

# ── Security & Authentication ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
JWT_SECRET=super_secret_jwt_signature_key_here
